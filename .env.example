# SehatAI Environment Configuration
# Copy this to .env.local and fill in the values

# --- HACKATHON DEMO CONFIG ---
# Set to 'true' to use hardcoded high-quality responses if APIs are slow/down
VITE_DEMO_MODE="true"
# Secret key for Admin Registration (ISO Gatekeeping)
VITE_ADMIN_SECRET_KEY="SEHAT_AI_ARCHITECT_2024"

# --- SUPABASE CONFIG ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# --- AI API KEYS ---
VITE_GEMINI_API_KEY="your-gemini-key"
VITE_GROQ_API_KEY="your-groq-key"
VITE_CALORIE_NINJAS_KEY="your-calorieninjas-key"

# --- FIREBASE CONFIG (Optional/Legacy) ---
VITE_FIREBASE_API_KEY="your-firebase-key"
VITE_FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
